PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/naija_transport_dev?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_refresh_secret_or_reuse_jwt_secret
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=naija_refresh_token
CORS_ORIGIN=http://localhost:5173
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=60
ROUTES_RATE_LIMIT_WINDOW_MS=60000
ROUTES_RATE_LIMIT_MAX=120
