PORT=5000
NODE_ENV=development
LOG_LEVEL=info
TRUST_PROXY_HOPS=1
ENFORCE_HTTPS=true
HSTS_MAX_AGE_SECONDS=63072000
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_CAPTURE_TEST_TOKEN=replace_with_random_sentry_capture_test_token

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/naija_transport_dev?retryWrites=true&w=majority
MONGO_URI_PROD=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/naija_transport_prod?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_refresh_secret_or_reuse_jwt_secret
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=naija_refresh_token
REFRESH_TOKEN_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173

SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=60
ROUTES_RATE_LIMIT_WINDOW_MS=60000
ROUTES_RATE_LIMIT_MAX=120

BOT_INGEST_TOKEN=replace_with_random_bot_ingest_token
BOT_REPORT_USER_ID=replace_with_existing_user_object_id

WHATSAPP_BOT_ENABLED=false
WHATSAPP_ALLOWED_SENDERS=
WHATSAPP_SESSION_PATH=.wwebjs_auth
WHATSAPP_PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_CACHE_DIR=

VITE_API_BASE=http://localhost:5000
VITE_MAPBOX_KEY=pk.replace_with_public_mapbox_token
